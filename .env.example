# Copy to `.env` and fill in. The .env file is git-ignored.
# In production, populate these via your orchestrator's env-var UI instead.

# ----- Production stack image source --------------------------------------
# Only consumed by `stack.yml` (the production compose). Set this to the
# host (and port, if non-default) of the registry you pushed the image to.
# Examples:
#   WW3_REGISTRY=registry.example.com
#   WW3_REGISTRY=registry.example.com:5000
WW3_REGISTRY=
WW3_IMAGE_TAG=latest

# ----- Postgres (time-series store) ---------------------------------------
POSTGRES_USER=ww3
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ww3

# ----- ACLED — political violence ----------------------------------------
# Free account at https://acleddata.com/register/ (1–2 business days for
# the data-read scope to be granted on a new account).
ACLED_USERNAME=
ACLED_PASSWORD=

# ----- Cloudflare Radar — internet attacks --------------------------------
# Create at https://dash.cloudflare.com/profile/api-tokens with the
# `radar:read` permission. Free tier is plenty for our cadence.
CLOUDFLARE_API_TOKEN=

# ----- n2yo — satellite tracking -----------------------------------------
# Free account at https://www.n2yo.com/login/
N2YO_API_KEY=

# ----- Electricity Maps — live grid mix ----------------------------------
# Token is account-scoped; default works for the zone associated with your
# Electricity Maps plan.
ELECTRICITYMAP_TOKEN=
ELECTRICITYMAP_ZONE=PT

# ----- OpenWeatherMap — conflict-zone weather ----------------------------
# Free key at https://home.openweathermap.org/api_keys
# Note: newly created keys can take up to ~2 hours to activate.
OPENWEATHER_API_KEY=

# ----- Liveuamap — live geo-tagged conflict events -----------------------
# Premium key from https://me.liveuamap.com/devapi
# After getting the key, also copy the example endpoint URL from the same
# page into LIVEUAMAP_ENDPOINT in src/lib/sources/liveuamap.ts.
LIVEUAMAP_API_KEY=

# ----- Operational --------------------------------------------------------
# Where the SQLite "latest snapshot" DB lives inside the container.
WW3_DATA_DIR=/data

# Background refresh interval in ms (15 minutes default).
WW3_REFRESH_INTERVAL_MS=900000

# Optional: set to 1 only after `npx playwright install chromium`.
HEADLESS_ENABLED=0
